# Nodeglow environment configuration
# Copy to .env and adjust values

# PostgreSQL (used by docker compose)
POSTGRES_DB=nodeglow
POSTGRES_USER=nodeglow
POSTGRES_PASSWORD=changeme

# App database URL (set automatically by docker compose)
# For SQLite (default if not set): leave empty
# For PostgreSQL: postgresql+asyncpg://nodeglow:changeme@db:5432/nodeglow
DATABASE_URL=postgresql+asyncpg://nodeglow:${POSTGRES_PASSWORD}@db:5432/nodeglow

# Secret key for encryption (auto-generated if not set)
# SECRET_KEY=

# Data directory (for SQLite DB + secret key file)
# DATA_DIR=/data
